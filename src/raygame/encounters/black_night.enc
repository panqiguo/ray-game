(def bedroom_circle_probe
  (check
    (title "试探迂回")
    (desc "你从边角绕进去，把话一点点逼近核心。")
    (suits reason instinct)
    (risk low)
    (ok "他被你绕开了防备。" (truth +1))
    (partial "你逼近了真相，但还差一口气。" (truth +1))
    (fail "他看穿了你的路子。" (alert +1))))

(def bedroom_leave
  (action
    (title "收手离开")
    (desc "你已经听到足够多的半句真话。")
    (before
      (finish 'abort))))

(def front_pick_lock
  (check
    (title "撬锁进入")
    (desc "你从正门进去，尽量别留下动静。")
    (suits reason instinct)
    (risk mid)
    (ok "门锁被你撬开了。" (set entry_method 'front))
    (partial "门开得不够干净，但你还是挤了进去。" (set entry_method 'front) (alert +1))
    (fail "锁发出一声轻响。" (alert +1))))

(def front_wait_gap
  (check
    (title "等巡查空档")
    (desc "你盯着屋里的人影，等他们错开。")
    (suits reason empathy)
    (risk low)
    (ok "你抓住了空档，悄悄从正门进去了。" (set entry_method 'front))
    (partial "你等得有点久，还是进去了。" (set entry_method 'front) (alert +1))
    (fail "你等得太久，外头的动静多了起来。" (alert +1))))

(def climb_window
  (check
    (title "翻上二楼窗户")
    (desc "你沿着排水管往上爬，从窗缝里翻进去。")
    (suits instinct force)
    (risk high)
    (ok "你无声翻进了二楼。" (set entry_method 'window))
    (partial "你擦伤了手，但还是进去了。" (set entry_method 'window) (health -1))
    (fail "你没抓稳，差点摔下去。" (health -1) (alert +1))))

(def left_start_patrol
  (action
    (title "扔石子")
    (desc "你把石头弹到视线外，引他转身去看。巡逻就从这一刻开始朝你压过来。")
    (before
      (set route 'left)
      (set patrol 1)
      (set traverse 0)
      (set dog_state 'calm)
      (set entry_method 'none))))

(def left_hold_position
  (action
    (title "压低呼吸")
    (desc "你先不冒进，只贴着阴影停住，等他这一轮手电扫过去。")
    (before
      (patrol +1))))

(def left_advance
  (check
    (title "趁隙穿越")
    (desc "你贴着墙往前压，赌他还没回头。")
    (suits reason instinct)
    (risk mid)
    (ok "你稳稳跨过一段。" (traverse +1) (patrol +1))
    (partial "你碰到了点动静，但还是往前挪了一步。" (traverse +1) (patrol +1) (alert +1))
    (fail "手电光差点扫到你。你只能先把呼吸压住。" (patrol +1) (alert +1))))

(def left_fight_guard
  (check
    (title "搏斗")
    (desc "你只能抢先动手，把人压回去。")
    (suits force)
    (risk high)
    (ok "保安倒下了，通路也开了。" (set route 'none) (set phase 'entry) (set traverse 0) (alert +1))
    (partial "你把他压住了，自己也挨了一下。" (set route 'none) (set phase 'entry) (set traverse 0) (health -1) (alert +1))
    (fail "你没压住他。" (health -2) (alert +2))))

(def left_berserk_rush
  (check
    (title "狠狠干硬闯")
    (desc "你不跟他绕，狠狠干着肩膀和步子直接撞穿这条走廊。")
    (suits force instinct)
    (risk high)
    (ok "你狠狠干翻了保安，直接冲到了屋外。" (set route 'none) (set phase 'entry) (set patrol 0) (set traverse 0) (alert +2))
    (partial "你是硬闯过去了，但自己也挨了一下。" (set route 'none) (set phase 'entry) (set patrol 0) (set traverse 0) (health -1) (alert +2))
    (fail "你刚冲出去就被堵了回来。" (set route 'left) (set patrol 2) (health -1) (alert +2))))

(def right_edge_forward
  (check
    (title "贴墙慢行")
    (desc "你贴着外墙慢慢挪，尽量不碰响任何东西。")
    (suits reason instinct)
    (risk mid)
    (ok "你无声挪过了一段。" (set route 'right) (set patrol 0) (traverse +1))
    (partial "你还是让它抬了头。你往前挪了一步。" (set route 'right) (set patrol 0) (traverse +1) (alert +1) (set dog_state 'agitated))
    (fail "狗开始低吠。" (set route 'right) (set patrol 0) (set traverse 0) (set dog_state 'agitated) (alert +1))))

(def drug_the_dog
  (check
    (title "投喂毒食")
    (desc "你把预备好的毒食丢进它够得着的地方。")
    (suits reason instinct)
    (risk high)
    (ok "狗安静了下来。" (set dog_state 'asleep) (traverse +1))
    (partial "它吃下去了，但还是挣扎了一下。" (set dog_state 'asleep) (traverse +1) (alert +1))
    (fail "它警觉地躲开了。" (alert +1))))

(def soothe_the_dog
  (check
    (title "低声安抚")
    (desc "你压低声音和动作，试着先让它把你当成没有威胁的东西。")
    (suits empathy instinct)
    (risk mid)
    (ok "它慢慢安静下来，你也顺势往前挪了一段。" (set route 'right) (set dog_state 'asleep) (traverse +1))
    (partial "它没有彻底放松，但也没立刻扑上来。" (set route 'right) (set dog_state 'agitated) (alert +1))
    (fail "它被你这一下彻底惊起来了。" (set route 'right) (set dog_state 'agitated) (alert +1))))

(def slip_past_dog
  (action
    (title "穿过小径")
    (desc "你放轻脚步，从它旁边穿过去。")
    (before
      (traverse +1))))

(def front_direct_inquiry
  (check
    (title "直接询问")
    (desc "你开门见山，问他到底在藏什么。")
    (suits reason empathy)
    (risk low)
    (ok "他沉默了一下，吐出了一点实话。" (truth +1))
    (partial "他没回答全部，但你听到了关键半句。" (truth +1) (alert +1))
    (fail "他把话题挡了回去。" (alert +1))))

(def front_present_evidence
  (check
    (title "摆出线索")
    (desc "你把一路摸来的痕迹摊给他看。")
    (suits reason empathy)
    (risk mid)
    (ok "他终于不再硬扛。" (truth +2))
    (partial "他承认了一半。" (truth +1) (alert +1))
    (fail "他知道你手里的东西还不够。" (alert +1))))

(def front_silent_pressure
  (check
    (title "沉默施压")
    (desc "你什么也不说，只是看着他。")
    (suits empathy instinct)
    (risk mid)
    (ok "他先败下阵来。" (truth +1) (alert +1))
    (partial "他开始坐不住了。" (truth +1) (alert +1))
    (fail "沉默压不住他。" (alert +1))))

(def window_direct_inquiry
  (check
    (title "直接询问")
    (desc "你开门见山，问他到底在藏什么。")
    (suits reason empathy)
    (risk mid)
    (ok "他沉默了一下，吐出了一点实话。" (truth +1))
    (partial "他没回答全部，但你听到了关键半句。" (truth +1) (alert +1))
    (fail "他把话题挡了回去。" (alert +1))))

(def window_present_evidence
  (check
    (title "摆出线索")
    (desc "你把一路摸来的痕迹摊给他看。")
    (suits reason empathy)
    (risk high)
    (ok "他终于不再硬扛。" (truth +2))
    (partial "他承认了一半。" (truth +1) (alert +1))
    (fail "他知道你手里的东西还不够。" (alert +1))))

(def window_silent_pressure
  (check
    (title "沉默施压")
    (desc "你什么也不说，只是看着他。")
    (suits empathy instinct)
    (risk high)
    (ok "他先败下阵来。" (truth +1) (alert +1))
    (partial "他开始坐不住了。" (truth +1) (alert +1))
    (fail "沉默压不住他。" (alert +1))))

(encounter
  (id black_night)
  (title "黑夜入宅")
  (desc "深夜潜入戒备森严的宅邸，只为听到一个真相。")
  (fail
    (stress +2))

  (store
    (clock alert "全局警觉度" 0 6)
    (clock patrol "保安巡逻" 0 3)
    (clock traverse "穿越进度" 0 2)
    (clock truth "真相" 0 3)
    (value phase 'yard)
    (value route 'none)
    (value dog_state 'calm)
    (value entry_method 'none))

  (reacts
    ((>= (clock-value alert) (clock-full alert))
     (finish 'fail))
    ((and (= phase 'yard) (= route 'left) (>= (clock-value traverse) (clock-full traverse)))
     (set phase 'entry)
     (set route 'none)
     (set patrol 0)
     (set traverse 0))
    ((and (= phase 'yard) (= route 'right) (= dog_state 'asleep) (>= (clock-value traverse) (clock-full traverse)))
     (set phase 'entry)
     (set route 'none)
     (set traverse 0))
    ((and (= phase 'entry) (not (= entry_method 'none)))
     (set phase 'bedroom))
    ((>= (clock-value truth) (clock-full truth))
     (finish 'success)))

  (view
    (cond
      ((>= (clock-value alert) (clock-full alert))
       (scene
         (id exposed)
         (title "暴露撤退")
         (desc "宅子里已经乱起来了。你没能把话听完，只能先退开。")
         (show-clocks alert truth)
         (actions)))

      ((= phase 'entry)
       (scene
         (id entry_outer)
         (title "房屋外墙")
         (desc "正门半掩，二楼窗户也留着一点缝。你得选一种进法。")
         (show-clocks alert)
         (actions)
         (children
           (scene
             (id front_door)
             (title "大门")
             (desc "门锁不算新，里头的人影偶尔会从门缝后晃过去。")
             (show-clocks alert)
             (actions
               front_pick_lock
               front_wait_gap))
           (scene
             (id upper_window)
             (title "窗户")
             (desc "排水管能借力，但二楼那扇窗只留了一道窄缝。")
             (show-clocks alert)
             (actions
               climb_window)))))

      ((= phase 'bedroom)
       (if (= entry_method 'front)
         (scene
           (id bedroom_front)
           (title "卧室")
           (desc "你从正门进来，老大抬头时明显愣了一下。")
           (show-clocks alert truth)
           (actions
             front_direct_inquiry
             bedroom_circle_probe
             front_present_evidence
             front_silent_pressure
             bedroom_leave))
         (scene
           (id bedroom_window)
           (title "卧室")
           (desc "你从窗户翻进来，他看你的眼神更冷，也更警觉。")
           (show-clocks alert truth)
           (actions
             window_direct_inquiry
             bedroom_circle_probe
             window_present_evidence
             window_silent_pressure
             bedroom_leave))))

      (else
       (scene
         (id yard_root)
         (title "院墙缺口")
         (desc "深夜。你站在宅邸外墙的阴影里。左边是保安巡逻的走廊，右边是看门犬守着的小径。")
         (show-clocks alert)
         (actions)
         (children
           (scene
             (id left_corridor)
             (title "左侧走廊")
             (desc "这条走廊没有遮挡。只要你已经把他引动，保安的巡逻就会一轮轮压过来；你在这里每拖一拍，他就更逼近一格。")
             (show-clocks alert patrol traverse)
             (actions
               (when (= (clock-value patrol) 0)
                 left_start_patrol)
               (when (< (clock-value traverse) (clock-full traverse))
                 left_berserk_rush)
               (when (and (= route 'left) (> (clock-value patrol) 0) (< (clock-value patrol) (clock-full patrol)) (< (clock-value traverse) (clock-full traverse)))
                 left_hold_position)
               (when (and (= route 'left) (> (clock-value patrol) 0) (< (clock-value traverse) (clock-full traverse)))
                 left_advance)
               (when (and (= route 'left) (= (clock-value patrol) (clock-full patrol)) (< (clock-value traverse) (clock-full traverse)))
                 left_fight_guard)))
           (scene
             (id right_path)
             (title "右侧小径")
             (desc "树影更浓，但看门犬一直守在这条窄小的小径边。")
             (show-clocks alert traverse)
             (actions
               (when (and (= dog_state 'calm) (< (clock-value traverse) (clock-full traverse)))
                 right_edge_forward)
               (when (and (or (= dog_state 'calm) (= dog_state 'agitated)) (< (clock-value traverse) (clock-full traverse)))
                 soothe_the_dog)
               (when (and (= route 'right) (= dog_state 'agitated))
                 drug_the_dog)
               (when (and (= route 'right) (= dog_state 'asleep) (< (clock-value traverse) (clock-full traverse)))
                 slip_past_dog)))))))))
