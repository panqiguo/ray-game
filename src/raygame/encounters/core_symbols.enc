; Shared literal bindings.
; These keep the runtime closer to pure Scheme rules:
; bare symbols are names, and common enum-like values come from defs.

; Risk levels
(def low 'low)
(def mid 'mid)
(def high 'high)

; Check suits
(def reason 'reason)
(def force 'force)
(def empathy 'empathy)
(def instinct 'instinct)

; Common encounter outcomes
(def success 'success)
(def fail 'fail)
(def abort 'abort)

; Common generic symbolic values
(def none 'none)

; Input kinds
(def any 'any)
(def negative 'negative)
